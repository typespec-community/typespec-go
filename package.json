{
  "name": "@typespec-community/typespec-go",
  "version": "0.0.1",
  "main": "dist/src/emitter/main.js",
  "devDependencies": {
    "@types/node": "latest",
    "@typespec/compiler": "1.7.0-dev.2",
    "@typespec/emitter-framework": "^0.14.0-dev.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "eslint": "^9.39.1",
    "prettier": "^4.0.0-alpha.12",
    "typescript": "6.0.0-dev.20251114",
    "bun": "latest"
  },
  "peerDependencies": {
    "@typespec/compiler": "1.7.0-dev.2"
  },
  "exports": {
    ".": {
      "types": "./dist/src/emitter/main.d.ts",
      "default": "./dist/src/emitter/main.js"
    }
  },

  "scripts": {
    "build": "bun build src/emitter/main.ts --outdir dist --target node --format esm",
    "build:check": "bunx tsc --noEmit --strict",
    "test": "bun test",
    "test:typespec": "bun test --timeout 30000",
    "lint": "eslint src/ --ext .ts --max-warnings 0",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier src/ --write"
  },
  "type": "module"
}